page {
  background: #fff7fb;
}

.page {
  padding: 24rpx;
}

.header-card {
  background: linear-gradient(135deg, #ffd9ec, #ffeef7);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 182, 193, 0.18);
}

.header-top {
  display: flex;
  align-items: center;
}

.header-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-right: 18rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5f4b5b;
  margin-bottom: 8rpx;
}

.sub-title {
  font-size: 24rpx;
  color: #8c6f7c;
}

.empty-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 56rpx 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(233, 197, 214, 0.14);
}

.empty-emoji {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #6a5362;
  margin-bottom: 10rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #a18593;
}

.bill-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(233, 197, 214, 0.14);
}

.bill-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.category-tag {
  display: inline-block;
  background: #ffe4f0;
  color: #7a5567;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

.amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #ff6fa7;
}

.income-amount {
  color: #20a66a !important;
}

.expense-amount {
  color: #ff6fa7 !important;
}

.remark {
  font-size: 30rpx;
  color: #4f4048;
  line-height: 1.7;
  margin-bottom: 18rpx;
  word-break: break-all;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 14rpx;
  border-top: 1rpx solid #f7e6ee;
}

.meta-text {
  font-size: 22rpx;
  color: #9b7b8a;
}
.delete-btn {
  margin-top: 20rpx;
  background: #fff0f5;
  color: #d85b8f;
  border: 2rpx solid #f6bfd6;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.delete-btn::after {
  border: none;
}
.action-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
}

.edit-btn,
.delete-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.edit-btn {
  background: #ffeef7;
  color: #b85c86;
  border: 2rpx solid #f6bfd6;
}

.edit-btn::after {
  border: none;
}

.delete-btn {
  background: #fff0f5;
  color: #d85b8f;
  border: 2rpx solid #f6bfd6;
}

.delete-btn::after {
  border: none;
}
