<view class="page">
  <view class="card">
    <view class="title">编辑账单</view>

    <view class="field">
      <view class="label">类型</view>
      <view class="type-switch">
        <button
          class="type-option {{type === '支出' ? 'type-option-active' : ''}}"
          data-type="支出"
          bindtap="onTypeChange"
        >
          支出
        </button>
        <button
          class="type-option {{type === '收入' ? 'type-option-income-active' : ''}}"
          data-type="收入"
          bindtap="onTypeChange"
        >
          收入
        </button>
      </view>
    </view>

    <view class="field">
      <view class="label">金额</view>
      <input class="input" type="digit" value="{{amount}}" bindinput="onAmountInput" />
    </view>

    <view class="field">
      <view class="label">分类</view>
      <input class="input" value="{{category}}" bindinput="onCategoryInput" />
    </view>

    <view class="field">
      <view class="label">备注</view>
      <input class="input" value="{{remark}}" bindinput="onRemarkInput" />
    </view>

    <button class="save-btn" bindtap="saveEdit">保存修改</button>
  </view>
</view>
