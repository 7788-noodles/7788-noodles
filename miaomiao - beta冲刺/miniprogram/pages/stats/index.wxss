page {
  background: #fff7fb;
}

.page {
  padding: 24rpx;
}

.header-card {
  background: linear-gradient(135deg, #ffd9ec, #ffeef7);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(255, 182, 193, 0.18);
  display: flex;
  align-items: center;
}

.header-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-right: 18rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5f4b5b;
  margin-bottom: 8rpx;
}

.sub-title {
  font-size: 24rpx;
  color: #8c6f7c;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(233, 197, 214, 0.14);
}

.month-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(233, 197, 214, 0.14);
}

.month-label {
  font-size: 26rpx;
  color: #8b6e7d;
  margin-bottom: 12rpx;
}

.month-picker {
  height: 76rpx;
  padding: 0 22rpx;
  border: 2rpx solid #ffd6e8;
  border-radius: 18rpx;
  background: #fff7fb;
  color: #5f4b5b;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.month-arrow {
  font-size: 24rpx;
  color: #b85c86;
  font-weight: 400;
}

.summary-card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.stat-item {
  padding: 12rpx 0;
}

.stat-label {
  font-size: 28rpx;
  color: #8b6e7d;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ff6fa7;
}

.income-text {
  color: #20a66a !important;
}

.expense-text {
  color: #ff6fa7 !important;
}

.divider {
  height: 1rpx;
  background: #f7e6ee;
  margin: 12rpx 0 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5f4b5b;
  margin-bottom: 18rpx;
}

.category-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f7e6ee;
}

.category-item:last-child {
  border-bottom: none;
}

.category-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.category-left {
  display: flex;
  align-items: center;
}

.category-right {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.category-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff9fc4;
  margin-right: 16rpx;
}

.income-dot {
  background: #20a66a;
}

.expense-dot {
  background: #ff9fc4;
}

.category-name {
  font-size: 28rpx;
  color: #6f5a67;
}

.category-percent {
  font-size: 24rpx;
  color: #b28799;
}

.category-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #ff6fa7;
}

.progress-track {
  width: 100%;
  height: 16rpx;
  background: #fde7f0;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffb3cf, #ff6fa7);
  border-radius: 999rpx;
}

.income-fill {
  background: linear-gradient(90deg, #8ee0ba, #20a66a);
}

.expense-fill {
  background: linear-gradient(90deg, #ffb3cf, #ff6fa7);
}

.empty-text {
  font-size: 26rpx;
  color: #9b7b8a;
  text-align: center;
  padding: 20rpx 0;
}
.analyze-btn {
  background: #ff8fbc;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  border: none;
  margin-top: 8rpx;
}

.analyze-btn::after {
  border: none;
}
.ai-block {
  background: #fff7fb;
  border: 2rpx solid #fde1ed;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-top: 18rpx;
}

.ai-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #b85c86;
  margin-bottom: 12rpx;
}

.ai-content {
  font-size: 28rpx;
  color: #5f4b5b;
  line-height: 1.8;
  word-break: break-all;
}
.analyze-btn-disabled {
  background: #d8a8bd !important;
  color: #fffafc !important;
}
